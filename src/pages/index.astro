---
import { getPublishedPosts } from '../lib/posts';
import Layout from '../layouts/Layout.astro';

const slugOf = (id: string) =>
  id
    .split('/')
    .map((seg) => seg.replace(/^\d{4}-\d{2}-\d{2}-/, ''))
    .join('/');
const fmtDate = (d: Date) => d.toISOString().slice(0, 10);
const base = import.meta.env.BASE_URL.replace(/\/$/, ''); // '/blog'
const tagUrl = (t: string) => `${base}/tags/${t}`;

const all = await getPublishedPosts();

const standalone = all
  .filter((p) => !p.data.series)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const seriesMap = new Map<string, typeof all>();
for (const p of all.filter((p) => p.data.series)) {
  const key = p.data.series as string;
  if (!seriesMap.has(key)) seriesMap.set(key, []);
  seriesMap.get(key)!.push(p);
}
for (const arr of seriesMap.values()) {
  arr.sort((a, b) => (a.data.series_order ?? 0) - (b.data.series_order ?? 0));
}
// 메인페이지 시리즈 노출 순서(명시적). 목록에 없는 시리즈는 뒤에 붙는다.
const SERIES_ORDER = [
  '시장의 인문학',
  '최소저항 경로의 법칙',
  '마켓 인사이트',
  '시장의 물리학',
  '트레이딩',
  '트레이딩 전략',
];
const seriesRank = (name: string) => {
  const i = SERIES_ORDER.indexOf(name);
  return i === -1 ? SERIES_ORDER.length : i;
};
const seriesList = [...seriesMap.entries()].sort(
  (a, b) => seriesRank(a[0]) - seriesRank(b[0]),
);
---

<Layout
  title="조대형의 트레이딩 인사이트"
  description="주식·투자·시장 분석 기록"
>
  <section class="intro">
    <h1>조대형의 트레이딩 인사이트</h1>
    <p class="lead">주식·투자·시장 분석 기록.</p>
  </section>

  {
    standalone.length > 0 && (
      <section class="post-section">
        <h2 class="section-title">글</h2>
        <ul class="post-list">
          {standalone.map((post) => (
            <li class="post-item">
              <h3 class="post-item-title">
                <a href={`${base}/${slugOf(post.id)}`}>{post.data.title}</a>
              </h3>
              <div class="post-item-meta">
                <time datetime={post.data.date.toISOString()}>{fmtDate(post.data.date)}</time>
                {post.data.tags?.slice(0, 5).map((t) => (
                  <a class="tag" href={tagUrl(t)}>#{t}</a>
                ))}
              </div>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {
    seriesList.map(([name, parts]) => (
      <section class="post-section">
        <h2 class="section-title">
          <span class="section-badge">시리즈</span>
          {name}
        </h2>
        <ul class="post-list">
          {parts.map((post) => (
            <li class="post-item">
              <h3 class="post-item-title">
                {post.data.series_label ? (
                  <span class="post-no">{post.data.series_label}</span>
                ) : post.data.series_order != null ? (
                  <span class="post-no">{post.data.series_order}편</span>
                ) : null}
                <a href={`${base}/${slugOf(post.id)}`}>{post.data.title}</a>
              </h3>
              <div class="post-item-meta">
                <time datetime={post.data.date.toISOString()}>{fmtDate(post.data.date)}</time>
                {post.data.tags?.slice(0, 5).map((t) => (
                  <a class="tag" href={tagUrl(t)}>#{t}</a>
                ))}
              </div>
            </li>
          ))}
        </ul>
      </section>
    ))
  }
</Layout>
