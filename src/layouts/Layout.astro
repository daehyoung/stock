---
interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
}
const { title, description, canonicalUrl } = Astro.props;
const home = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';
---

<!doctype html>
<html lang="ko" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}

    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css"
    />

    <!-- 테마 초기화 (FOUC 방지) -->
    <script is:inline>
      (() => {
        const saved = localStorage.getItem('theme');
        const sys = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        document.documentElement.dataset.theme = saved ?? sys;
      })();
    </script>
  </head>

  <body>
    <header class="site-header">
      <div class="bar">
        <a href={home} class="site-title">조대형의 주식 노트</a>
        <nav class="nav">
          <a href={home + 'tags'} class="nav-link">태그</a>
          <button id="theme-toggle" type="button" aria-label="라이트/다크 모드 전환">
            <svg class="ic ic-moon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
            <svg class="ic ic-sun" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
          </button>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>
        © 조대형 · 글은 <a href="https://creativecommons.org/licenses/by-nc/4.0/">CC BY-NC 4.0</a>
      </p>
    </footer>

    <script is:inline>
      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
        document.documentElement.dataset.theme = next;
        localStorage.setItem('theme', next);
      });

      // 이메일 난독화 해제: 봇이 보는 정적 HTML엔 'user [at] domain'만, 방문자에겐 실제 주소
      document.querySelectorAll('a.email[data-user]').forEach((a) => {
        const addr = a.dataset.user + '@' + a.dataset.domain;
        a.setAttribute('href', 'mailto:' + addr);
        a.textContent = addr;
      });
    </script>

    <style is:global>
      :root {
        --w: 720px;
        --bg: #fdfdfd;
        --fg: #1c1e21;
        --muted: #6b7280;
        --border: #e7e9ec;
        --card: #ffffff;
        --card-hover: #fbfcff;
        --accent: #2563eb;
        --accent-soft: rgba(37, 99, 235, 0.09);
        --code-inline: #f2f4f6;
        --shadow: 0 1px 2px rgba(0, 0, 0, 0.04), 0 8px 24px rgba(0, 0, 0, 0.06);
      }
      html[data-theme='dark'] {
        --bg: #0f1217;
        --fg: #e8eaed;
        --muted: #9aa3ad;
        --border: #262b33;
        --card: #161a21;
        --card-hover: #1a1f28;
        --accent: #6aa6ff;
        --accent-soft: rgba(106, 166, 255, 0.13);
        --code-inline: #1d222b;
        --shadow: 0 1px 2px rgba(0, 0, 0, 0.3), 0 8px 24px rgba(0, 0, 0, 0.35);
      }

      * { box-sizing: border-box; }
      html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--fg);
        font-family: 'Pretendard Variable', Pretendard, -apple-system, BlinkMacSystemFont,
          system-ui, 'Apple SD Gothic Neo', 'Noto Sans KR', sans-serif;
        font-size: 17px;
        line-height: 1.75;
        transition: background-color 0.2s ease, color 0.2s ease;
        -webkit-font-smoothing: antialiased;
      }

      /* ── 헤더 ── */
      .site-header {
        position: sticky;
        top: 0;
        z-index: 10;
        background: color-mix(in srgb, var(--bg) 88%, transparent);
        backdrop-filter: saturate(180%) blur(8px);
        border-bottom: 1px solid var(--border);
      }
      .bar {
        max-width: var(--w);
        margin: 0 auto;
        padding: 14px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .site-title {
        font-weight: 700;
        font-size: 17px;
        letter-spacing: -0.01em;
        text-decoration: none;
        color: var(--fg);
      }
      #theme-toggle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border: 1px solid var(--border);
        border-radius: 9px;
        background: var(--card);
        color: var(--fg);
        cursor: pointer;
        transition: border-color 0.15s, background 0.15s;
      }
      #theme-toggle:hover { border-color: var(--accent); color: var(--accent); }
      .nav { display: flex; align-items: center; gap: 14px; }
      .nav-link { font-size: 14px; font-weight: 600; text-decoration: none; color: var(--muted); }
      .nav-link:hover { color: var(--accent); }
      .ic-sun { display: none; }
      html[data-theme='dark'] .ic-sun { display: inline; }
      html[data-theme='dark'] .ic-moon { display: none; }

      main { max-width: var(--w); margin: 0 auto; padding: 8px 20px 72px; }
      .site-footer {
        max-width: var(--w);
        margin: 0 auto;
        padding: 28px 20px 48px;
        border-top: 1px solid var(--border);
        color: var(--muted);
        font-size: 14px;
      }
      a { color: var(--accent); text-underline-offset: 2px; }

      /* ── 홈 ── */
      .intro { padding: 28px 0 8px; }
      .intro h1 { font-size: 1.9rem; margin: 0 0 8px; letter-spacing: -0.02em; }
      .lead { color: var(--muted); margin: 0; }
      .post-section { margin-top: 36px; }
      .section-title {
        font-size: 1.15rem;
        display: flex;
        align-items: center;
        gap: 8px;
        margin: 0 0 6px;
        padding-bottom: 9px;
        border: 0;
        border-bottom: 1px solid var(--border);
      }
      .section-badge {
        font-size: 0.72rem;
        font-weight: 700;
        color: var(--accent);
        background: var(--accent-soft);
        padding: 3px 8px;
        border-radius: 999px;
        letter-spacing: 0.02em;
      }
      /* AstroPaper풍 단순 목록 — 카드 박스 없이 제목+메타 */
      .post-list { list-style: none; margin: 0; padding: 0; }
      .post-item { padding: 12px 0; }
      .post-item-title {
        font-size: 1.2rem;
        font-weight: 600;
        margin: 0 0 5px;
        line-height: 1.45;
        letter-spacing: -0.01em;
      }
      .post-item-title a {
        color: var(--accent);
        text-decoration: none;
        text-underline-offset: 4px;
      }
      .post-item-title a:hover {
        text-decoration: underline;
        text-decoration-style: dashed;
      }
      .post-no {
        display: inline-block;
        font-size: 0.78rem;
        font-weight: 700;
        color: var(--accent);
        background: var(--accent-soft);
        padding: 1px 7px;
        border-radius: 6px;
        margin-right: 7px;
        vertical-align: 0.1em;
      }
      .post-item-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; color: var(--muted); font-size: 13px; }
      .hash { color: var(--accent); }
      .tag {
        font-size: 12px;
        color: var(--muted);
        background: color-mix(in srgb, var(--border) 45%, transparent);
        padding: 2px 8px;
        border-radius: 999px;
      }
      a.tag { text-decoration: none; transition: color 0.14s, background 0.14s; }
      a.tag:hover { color: var(--accent); background: var(--accent-soft); }

      /* 태그 클라우드 (태그 목록 페이지) */
      .tag-cloud { display: flex; flex-wrap: wrap; gap: 9px; margin-top: 18px; }
      .tag-lg { font-size: 14px; padding: 6px 12px; display: inline-flex; align-items: center; gap: 7px; }
      .tag-count {
        font-size: 11px;
        color: var(--muted);
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 999px;
        padding: 0 6px;
        line-height: 1.5;
      }

      /* ── 글 페이지 ── */
      .back-link { display: inline-block; margin: 22px 0 4px; font-size: 14px; text-decoration: none; }
      .back-link:hover { text-decoration: underline; }
      article h1 { font-size: 2rem; line-height: 1.3; margin: 0.5em 0 0.5em; letter-spacing: -0.02em; }
      .post-byline {
        color: var(--muted);
        font-size: 14px;
        line-height: 1.7;
        padding-bottom: 1.4em;
        margin-bottom: 1.8em;
        border-bottom: 1px solid var(--border);
      }
      .byline-line { margin: 0; }
      .email { color: var(--accent); text-decoration: none; word-break: break-all; }
      .email:hover { text-decoration: underline; }
      .post-tags { display: flex; flex-wrap: wrap; gap: 8px; margin: 12px 0 0; }

      h2 {
        font-size: 1.5rem;
        margin: 1.9em 0 0.5em;
        padding-bottom: 0.25em;
        border-bottom: 1px solid var(--border);
        letter-spacing: -0.01em;
      }
      h3 { font-size: 1.2rem; margin: 1.6em 0 0.4em; }
      h4 { font-size: 1.05rem; margin: 1.4em 0 0.3em; }
      p, ul, ol { margin: 0.85em 0; }
      li { margin: 0.3em 0; }
      img { max-width: 100%; height: auto; border-radius: 8px; }
      hr { border: 0; border-top: 1px solid var(--border); margin: 2.2em 0; }

      blockquote {
        margin: 1.1em 0;
        padding: 0.5em 1.1em;
        border-left: 3px solid var(--accent);
        background: var(--accent-soft);
        border-radius: 0 8px 8px 0;
        color: var(--fg);
      }
      blockquote p { margin: 0.4em 0; }

      /* 인라인 코드 */
      :not(pre) > code {
        background: var(--code-inline);
        padding: 0.15em 0.4em;
        border-radius: 5px;
        font-size: 0.86em;
        font-family: ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Consolas, monospace;
      }
      /* 코드 블록 (shiki 듀얼 테마) */
      pre.astro-code {
        padding: 16px 18px;
        border-radius: 10px;
        overflow-x: auto;
        border: 1px solid var(--border);
        font-size: 0.86em;
        line-height: 1.6;
        background-color: var(--shiki-light-bg);
      }
      pre.astro-code,
      pre.astro-code span { color: var(--shiki-light); }
      html[data-theme='dark'] pre.astro-code { background-color: var(--shiki-dark-bg); }
      html[data-theme='dark'] pre.astro-code,
      html[data-theme='dark'] pre.astro-code span { color: var(--shiki-dark); }
      pre.astro-code code { background: none; padding: 0; font-size: 1em; }

      table {
        border-collapse: collapse;
        width: 100%;
        display: block;
        overflow-x: auto;
        margin: 1.2em 0;
        font-size: 0.92em;
      }
      th, td { border: 1px solid var(--border); padding: 8px 11px; text-align: left; }
      th { background: color-mix(in srgb, var(--border) 35%, transparent); font-weight: 600; }
      tr:nth-child(even) td { background: color-mix(in srgb, var(--border) 14%, transparent); }
    </style>
  </body>
</html>
